# Production/VPS backend URL.
# Current VPS public IP:
VITE_API_BASE_URL=http://54.255.167.56:8080

# If you use a domain/HTTPS later, replace with:
# VITE_API_BASE_URL=https://buddy-api.fanme.asia
#
# Local dev:
# - Use Vite proxy by leaving VITE_API_BASE_URL empty:
#   VITE_API_BASE_URL=
# - Or call backend directly:
#   VITE_API_BASE_URL=http://localhost:8080

# Dev-only backend target used by vite.config.ts proxy.
DEV_BACKEND_URL=http://localhost:8080

# Logto Production tenant endpoint.
VITE_LOGTO_ENDPOINT=https://o5rihz.logto.app/

# Logto SPA application ID. Replace this after copying to .env.
VITE_LOGTO_APP_ID=your_logto_app_id_here

# Logto Free tenant flow:
# - No custom API Resource required.
# - Leave empty so frontend requests the regular Logto access token.
VITE_LOGTO_API_RESOURCE=
