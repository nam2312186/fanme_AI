# Local dev:
# - Leave VITE_API_BASE_URL empty if Vite proxy forwards /api/* to backend.
# - Or set it to http://localhost:8080.
# VITE_API_BASE_URL=

# Production/VPS:
# Set this to the public chat app backend URL.
# Example with current VPS public IP:
VITE_API_BASE_URL=http://54.255.167.56:8080

# Dev-only backend target used by vite.config.ts proxy.
DEV_BACKEND_URL=http://localhost:8080

VITE_LOGTO_ENDPOINT=https://o5rihz.logto.app/
VITE_LOGTO_APP_ID=your_logto_app_id_here
VITE_LOGTO_API_RESOURCE=https://fanme-chat-api
