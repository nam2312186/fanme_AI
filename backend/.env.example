# =========================
# SERVER
# =========================
PORT=8080

# Comma-separated frontend origins allowed to call this backend.
# Current VPS public IP:
FRONTEND_ORIGINS=http://54.255.167.56

# If you run frontend dev/preview directly on the VPS, add its origin too, for example:
# FRONTEND_ORIGINS=http://54.255.167.56,http://54.255.167.56:5173,http://localhost:5173
#
# If you use a domain/HTTPS later, replace with:
# FRONTEND_ORIGINS=https://buddy.fanme.asia

# =========================
# DATABASE
# =========================
# SQLite file. For VPS production, use prod.db and keep it out of git.
DATABASE_URL=file:./prod.db

# =========================
# LOGTO AUTH
# =========================
# Logto Production tenant endpoint.
LOGTO_ENDPOINT=https://o5rihz.logto.app/

# Logto Free tenant flow:
# - No custom API Resource required.
# - No chat:internal scope required.
# - Backend verifies the token by calling LOGTO_ENDPOINT/oidc/me.
# Keep this empty.
LOGTO_API_RESOURCE=

# Optional email-domain allowlist. Leave empty if admin disables public sign-up
# and manually creates users in Logto UI.
# Example: ALLOWED_EMAIL_DOMAINS=fanme.vn,fanme.asia
ALLOWED_EMAIL_DOMAINS=

# =========================
# ANYTHINGLLM
# =========================
# AnythingLLM base URL.
# Local dev example:
# ANYTHINGLLM_BASE_URL=http://127.0.0.1:3001
# VPS -> local machine over Tailscale:
ANYTHINGLLM_BASE_URL=http://100.72.58.9:3001

# API key from AnythingLLM > Settings > API Keys.
# Keep this secret. Never put it in frontend env.
ANYTHINGLLM_API_KEY=your_anythingllm_api_key_here

# Workspace slug, not display name.
ANYTHINGLLM_WORKSPACE_SLUG=test_internal

# Non-streaming endpoint. Streaming automatically uses /stream-chat.
ANYTHINGLLM_CHAT_ENDPOINT=/api/v1/workspace/{slug}/chat

# query = only answer from workspace documents.
# chat = normal chat; if workspace agent is enabled in AnythingLLM UI, it can use agent tools.
# "agent" is not a valid API mode here.
ANYTHINGLLM_CHAT_MODE=chat

# Timeout in milliseconds.
# Keep long enough for agent/tool calls.
ANYTHINGLLM_TIMEOUT_MS=1200000
