# =========================
# SERVER
# =========================
PORT=8080

# Comma-separated frontend origins allowed to call this backend.
# Local dev example:
# FRONTEND_ORIGINS=http://localhost:5173,https://localhost:5173
# VPS production example:
# FRONTEND_ORIGINS=https://chat.example.com,http://54.255.167.56
FRONTEND_ORIGINS=http://54.255.167.56,http://localhost:5173

# =========================
# DATABASE
# =========================
# SQLite file. For VPS production, use prod.db and keep it out of git.
DATABASE_URL=file:./prod.db

# =========================
# LOGTO AUTH
# =========================
LOGTO_ENDPOINT=https://o5rihz.logto.app/
LOGTO_API_RESOURCE=https://fanme-chat-api

# =========================
# ANYTHINGLLM
# =========================
# AnythingLLM base URL.
# Local dev example:
# ANYTHINGLLM_BASE_URL=http://127.0.0.1:3001
# VPS -> local machine over Tailscale example:
# ANYTHINGLLM_BASE_URL=http://100.72.58.9:3001
ANYTHINGLLM_BASE_URL=http://100.72.58.9:3001

# API key from AnythingLLM > Settings > API Keys.
# Keep this secret. Never put it in frontend env.
ANYTHINGLLM_API_KEY=your_anythingllm_api_key_here

# Workspace slug, not display name.
ANYTHINGLLM_WORKSPACE_SLUG=test_internal

# Non-streaming endpoint. Streaming automatically uses /stream-chat.
ANYTHINGLLM_CHAT_ENDPOINT=/api/v1/workspace/{slug}/chat

# query = only answer from workspace documents.
# chat = normal chat; if workspace agent is enabled in AnythingLLM UI, it can use agent tools.
# "agent" is not a valid API mode here.
ANYTHINGLLM_CHAT_MODE=chat

# Timeout in milliseconds.
ANYTHINGLLM_TIMEOUT_MS=30000
